# App
DEBUG=false
ENV=development
PORT=8000
FRONTEND_URL=http://localhost:3000

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=cravvy

# Redis
REDIS_URL=redis://localhost:6379
REDIS_SESSION_TTL_SECONDS=604800

# Auth
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Claude AI
ANTHROPIC_API_KEY=

# Integrations (per-user OAuth tokens stored in DB)
ZOMATO_CLIENT_ID=
ZOMATO_CLIENT_SECRET=
SWIGGY_CLIENT_ID=
SWIGGY_CLIENT_SECRET=

# Email (Resend)
RESEND_API_KEY=
FROM_EMAIL=noreply@cravvy.app
