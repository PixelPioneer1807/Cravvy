# App
DEBUG=false
ENV=development
PORT=8000
FRONTEND_URL=http://localhost:3000

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=cravvy

# Redis
REDIS_URL=redis://localhost:6379
REDIS_SESSION_TTL_SECONDS=604800

# Auth
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Encryption — AES-256-GCM key for PII at rest (64 hex chars = 32 bytes)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=

# AI — Default provider (Groq free tier)
# Users can BYO key for any supported provider via the UI
GROQ_API_KEY=

# Integrations (per-user OAuth tokens stored in DB)
ZOMATO_CLIENT_ID=
ZOMATO_CLIENT_SECRET=
SWIGGY_CLIENT_ID=
SWIGGY_CLIENT_SECRET=
ZEPTO_CLIENT_ID=
ZEPTO_CLIENT_SECRET=

# Edamam — Recipe Search API (free: 10K calls/month)
# Get keys at: https://developer.edamam.com
EDAMAM_APP_ID=
EDAMAM_APP_KEY=

# Google Maps Platform (free: $200/month credit)
# Get key at: https://console.cloud.google.com
GOOGLE_MAPS_API_KEY=

# Email (Resend)
RESEND_API_KEY=
FROM_EMAIL=noreply@cravvy.app
